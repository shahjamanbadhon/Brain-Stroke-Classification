ndef plot_multiclass_roc(model, dataloader, class_names, device, dataset_name=\"Test Set\"):\n    print(f\"\\nGenerating ROC Curve for: {dataset_name}...\")\n    model.eval()\n    y_true, y_probs = [], []\n    \n    with torch.inference_mode():\n        for X, y in dataloader:\n            X = X.to(device)\n            outputs = model(X)\n            probabilities = torch.softmax(outputs.logits, dim=1)\n            y_true.extend(y.cpu().numpy())\n            y_probs.extend(probabilities.cpu().numpy())\n            \n    y_true = np.array(y_true)\n    y_probs = np.array(y_probs)\n    n_classes = len(class_names)\n    y_true_bin = label_binarize(y_true, classes=range(n_classes))\n    \n    plt.figure(figsize=(8, 6))\n    colors = ['blue', 'green', 'red'] \n    for i in range(n_classes):\n        fpr, tpr, _ = roc_curve(y_true_bin[:, i], y_probs[:, i])\n        roc_auc = auc(fpr, tpr)\n        plt.plot(fpr, tpr, color=colors[i], lw=2, label=f'{class_names[i]} (AUC = {roc_auc:.3f})')\n                 \n    plt.plot([0, 1], [0, 1], 'k--', lw=2, label='Random Guessing')\n    plt.xlim([0.0, 1.0])\n    plt.ylim([0.0, 1.05])\n    plt.xlabel('False Positive Rate', fontsize=12)\n    plt.ylabel('True Positive Rate', fontsize=12)\n    plt.title(f'ROC Curve: {dataset_name}', fontsize=14, fontweight='bold')\n    plt.legend(loc=\"lower right\", fontsize=10)\n    plt.grid(alpha=0.3)\n    plt.show()\n\nplot_multiclass_roc(vit, test_dataloader, class_names, Config.DEVICE, dataset_name=\"Standard Test Set\")\nplot_multiclass_roc(vit, ext_test_dataloader, class_names, Config.DEVICE, dataset_name=\"External Test Set\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-21T19:02:04.905528Z","iopub.execute_input":"2026-05-21T19:02:04.906023Z","iopub.status.idle":"2026-05-21T19:02:49.911339Z","shell.execute_reply.started":"2026-05-21T19:02:04.905974Z","shell.execute_reply":"2026-05-21T19:02:49.910533Z"}},"outputs":[{"name":"stdout","text":"\nGenerating ROC Curve for: Standard Test Set...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 800x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\nGenerating ROC Curve for: External Test Set...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 800x600 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":12},{"cell_type":"code","source":"# =======================================================\n# COMPLETE PIPELINE FOR KAGGLE - PAPER STANDARD FORMAT\n# =======================================================\n\nimport os\nimport json\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import classification_report, confusion_matrix, roc_curve, auc\nfrom sklearn.preprocessing import label_binarize\nimport torch\nfrom torch import nn\nimport zipfile\nfrom datetime import datetime\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# =======================================================\n# 1. CREATE OUTPUT DIRECTORY STRUCTURE\n# =======================================================\n\nBASE_DIR = \"/kaggle/working/medical_image_classification_results\"\nos.makedirs(BASE_DIR, exist_ok=True)\n\n# Create subdirectories\ndirs = {\n    'figures': os.path.join(BASE_DIR, 'figures'),\n    'metrics': os.path.join(BASE_DIR, 'metrics'),\n    'models': os.path.join(BASE_DIR, 'models'),\n    'reports': os.path.join(BASE_DIR, 'reports'),\n    'logs': os.path.join(BASE_DIR, 'logs')\n}\n\nfor dir_path in dirs.values():\n    os.makedirs(dir_path, exist_ok=True)\n\nprint(f\"✅ Results will be saved to: {BASE_DIR}\")\nprint(f\"✅ Current time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n\n# =======================================================\n# 2. YOUR TRAINED MODEL AND DATALOADERS (YOUR EXISTING CODE)\n# =======================================================\n\n# Your class names (modify according to your dataset)\nclass_names = ['Class_0', 'Class_1', 'Class_2']  # Replace with actual class names\n\n# Your existing trained model (vit) and dataloaders\n# vit = your_trained_model\n# test_dataloader = your_test_dataloader\n# ext_test_dataloader = your_external_test_dataloader\n\n# =======================================================\n# 3. ENHANCED PLOTTING FUNCTION WITH SAVING\n# =======================================================\n\ndef plot_and_save_curves(results, save_dir):\n    \"\"\"\n    Plot loss and accuracy curves and save them\n    \"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"PLOTTING TRAINING CURVES\")\n    print(\"=\"*60)\n    \n    # Create figure\n    fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n    \n    # Loss curves\n    axes[0].plot(results[\"train_loss\"], label=\"Train Loss\", linewidth=2, color='blue')\n    axes[0].plot(results[\"test_loss\"], label=\"Validation Loss\", linewidth=2, color='red')\n    axes[0].set_title(\"Loss Curves\", fontsize=14, fontweight='bold')\n    axes[0].set_xlabel(\"Epoch\", fontsize=12)\n    axes[0].set_ylabel(\"Loss\", fontsize=12)\n    axes[0].legend(fontsize=10, loc='upper right')\n    axes[0].grid(True, alpha=0.3)\n    \n    # Accuracy curves\n    axes[1].plot(results[\"train_acc\"], label=\"Train Accuracy\", linewidth=2, color='blue')\n    axes[1].plot(results[\"test_acc\"], label=\"Validation Accuracy\", linewidth=2, color='red')\n    if \"ext_test_acc\" in results and results[\"ext_test_acc\"]:\n        axes[1].plot(results[\"ext_test_acc\"], label=\"External Test Accuracy\", \n                    linewidth=2, color='green', linestyle='--')\n    axes[1].set_title(\"Accuracy Curves\", fontsize=14, fontweight='bold')\n    axes[1].set_xlabel(\"Epoch\", fontsize=12)\n    axes[1].set_ylabel(\"Accuracy (%)\", fontsize=12)\n    axes[1].legend(fontsize=10, loc='lower right')\n    axes[1].grid(True, alpha=0.3)\n    \n    plt.tight_layout()\n    \n    # Save figure\n    save_path = os.path.join(save_dir, 'training_curves.png')\n    plt.savefig(save_path, dpi=300, bbox_inches='tight')\n    plt.savefig(os.path.join(save_dir, 'training_curves.pdf'), bbox_inches='tight')\n    print(f\"✅ Training curves saved to: {save_path}\")\n    \n    plt.show()\n    \n    return fig\n\n# =======================================================\n# 4. ENHANCED EVALUATION FUNCTION WITH SAVING\n# =======================================================\n\ndef evaluate_and_save_metrics(model, dataloader, class_names, device, \n                              dataset_name=\"Test Set\", save_dir=None):\n    \"\"\"\n    Evaluate model and save metrics, confusion matrix, and classification report\n    \"\"\"\n    print(f\"\\n{'='*60}\")\n    print(f\"EVALUATING ON: {dataset_name}\")\n    print(f\"{'='*60}\\n\")\n    \n    model.eval()\n    y_true, y_pred = [], []\n    \n    with torch.inference_mode():\n        for X, y in dataloader:\n            X = X.to(device)\n            outputs = model(X)\n            # Handle different output types (ViT, standard model)\n            if hasattr(outputs, 'logits'):\n                predictions = torch.argmax(outputs.logits, dim=1)\n            else:\n                predictions = torch.argmax(outputs, dim=1)\n            y_true.extend(y.cpu().numpy())\n            y_pred.extend(predictions.cpu().numpy())\n    \n    # Generate classification report\n    report = classification_report(y_true, y_pred, target_names=class_names, output_dict=True)\n    report_df = pd.DataFrame(report).transpose()\n    \n    print(\"--- CLASSIFICATION REPORT ---\")\n    print(classification_report(y_true, y_pred, target_names=class_names))\n    \n    # Save classification report\n    if save_dir:\n        report_path = os.path.join(save_dir, f'{dataset_name}_classification_report.csv')\n        report_df.to_csv(report_path)\n        print(f\"✅ Classification report saved to: {report_path}\")\n        \n        # Save as JSON\n        json_path = os.path.join(save_dir, f'{dataset_name}_metrics.json')\n        with open(json_path, 'w') as f:\n            json.dump(report, f, indent=4)\n    \n    # Confusion matrix\n    cm = confusion_matrix(y_true, y_pred)\n    \n    # Plot confusion matrix\n    fig, ax = plt.subplots(figsize=(8, 7))\n    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', \n                xticklabels=class_names, yticklabels=class_names,\n                annot_kws={'size': 12}, ax=ax)\n    ax.set_title(f'Confusion Matrix: {dataset_name}', fontsize=14, fontweight='bold')\n    ax.set_ylabel('True Label', fontsize=12)\n    ax.set_xlabel('Predicted Label', fontsize=12)\n    plt.tight_layout()\n    \n    # Save confusion matrix\n    if save_dir:\n        cm_path = os.path.join(save_dir, f'{dataset_name}_confusion_matrix.png')\n        plt.savefig(cm_path, dpi=300, bbox_inches='tight')\n        plt.savefig(os.path.join(save_dir, f'{dataset_name}_confusion_matrix.pdf'), \n                   bbox_inches='tight')\n        print(f\"✅ Confusion matrix saved to: {cm_path}\")\n    \n    plt.show()\n    \n    # Calculate and return accuracy\n    accuracy = np.sum(np.array(y_true) == np.array(y_pred)) / len(y_true)\n    print(f\"\\n📊 Accuracy: {accuracy:.4f} ({accuracy*100:.2f}%)\\n\")\n    \n    return accuracy, report, cm\n\n# =======================================================\n# 5. ENHANCED ROC CURVE FUNCTION WITH SAVING\n# =======================================================\n\ndef plot_and_save_roc_curves(model, dataloader, class_names, device, \n                             dataset_name=\"Test Set\", save_dir=None):\n    \"\"\"\n    Plot multi-class ROC curves and save them\n    \"\"\"\n    print(f\"\\n{'='*60}\")\n    print(f\"GENERATING ROC CURVES FOR: {dataset_name}\")\n    print(f\"{'='*60}\\n\")\n    \n    model.eval()\n    y_true, y_probs = [], []\n    \n    with torch.inference_mode():\n        for X, y in dataloader:\n            X = X.to(device)\n            outputs = model(X)\n            \n            # Get probabilities\n            if hasattr(outputs, 'logits'):\n                probabilities = torch.softmax(outputs.logits, dim=1)\n            else:\n                probabilities = torch.softmax(outputs, dim=1)\n            \n            y_true.extend(y.cpu().numpy())\n            y_probs.extend(probabilities.cpu().numpy())\n    \n    y_true = np.array(y_true)\n    y_probs = np.array(y_probs)\n    n_classes = len(class_names)\n    y_true_bin = label_binarize(y_true, classes=range(n_classes))\n    \n    # Create color palette\n    colors = plt.cm.Set2(np.linspace(0, 1, n_classes))\n    \n    # Plot ROC curves\n    fig, ax = plt.subplots(figsize=(10, 8))\n    \n    roc_aucs = {}\n    for i in range(n_classes):\n        fpr, tpr, _ = roc_curve(y_true_bin[:, i], y_probs[:, i])\n        roc_auc = auc(fpr, tpr)\n        roc_aucs[class_names[i]] = roc_auc\n        ax.plot(fpr, tpr, color=colors[i], lw=2, \n                label=f'{class_names[i]} (AUC = {roc_auc:.3f})')\n    \n    # Plot diagonal line\n    ax.plot([0, 1], [0, 1], 'k--', lw=2, label='Random Guessing (AUC = 0.5)')\n    \n    ax.set_xlim([0.0, 1.0])\n    ax.set_ylim([0.0, 1.05])\n    ax.set_xlabel('False Positive Rate (1 - Specificity)', fontsize=12)\n    ax.set_ylabel('True Positive Rate (Sensitivity)', fontsize=12)\n    ax.set_title(f'ROC Curves - {dataset_name}', fontsize=14, fontweight='bold')\n    ax.legend(loc=\"lower right\", fontsize=10)\n    ax.grid(True, alpha=0.3)\n    \n    plt.tight_layout()\n    \n    # Save ROC curves\n    if save_dir:\n        roc_path = os.path.join(save_dir, f'{dataset_name}_roc_curves.png')\n        plt.savefig(roc_path, dpi=300, bbox_inches='tight')\n        plt.savefig(os.path.join(save_dir, f'{dataset_name}_roc_curves.pdf'), \n                   bbox_inches='tight')\n        print(f\"✅ ROC curves saved to: {roc_path}\")\n        \n        # Save AUC scores\n        auc_path = os.path.join(save_dir, f'{dataset_name}_auc_scores.json')\n        with open(auc_path, 'w') as f:\n            json.dump(roc_aucs, f, indent=4)\n        print(f\"✅ AUC scores saved to: {auc_path}\")\n    \n    plt.show()\n    \n    # Print AUC scores\n    print(\"\\n📊 AUC Scores:\")\n    for class_name, auc_score in roc_aucs.items():\n        print(f\"   {class_name}: {auc_score:.4f}\")\n    \n    return roc_aucs\n\n# =======================================================\n# 6. SAVE MODEL AND CREATE SUMMARY REPORT\n# =======================================================\n\ndef save_model_and_create_summary(model, results, test_accuracy, ext_test_accuracy, \n                                  save_dir, model_name=\"best_model\"):\n    \"\"\"\n    Save the trained model and create a summary report\n    \"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"SAVING MODEL AND CREATING SUMMARY REPORT\")\n    print(\"=\"*60)\n    \n    # Save model\n    model_path = os.path.join(save_dir, f'{model_name}.pth')\n    torch.save({\n        'model_state_dict': model.state_dict(),\n        'results': results,\n        'final_test_accuracy': test_accuracy,\n        'external_test_accuracy': ext_test_accuracy\n    }, model_path)\n    print(f\"✅ Model saved to: {model_path}\")\n    \n    # Create summary report\n    summary = {\n        'training_completed': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n        'final_epoch': len(results['train_loss']),\n        'final_train_loss': results['train_loss'][-1],\n        'final_val_loss': results['test_loss'][-1],\n        'final_train_accuracy': results['train_acc'][-1],\n        'final_val_accuracy': results['test_acc'][-1],\n        'best_val_accuracy': max(results['test_acc']),\n        'best_epoch': np.argmax(results['test_acc']) + 1,\n        'test_set_accuracy': test_accuracy,\n        'external_test_accuracy': ext_test_accuracy if ext_test_accuracy else None\n    }\n    \n    # Save summary\n    summary_path = os.path.join(save_dir, 'training_summary.json')\n    with open(summary_path, 'w') as f:\n        json.dump(summary, f, indent=4)\n    print(f\"✅ Training summary saved to: {summary_path}\")\n    \n    # Create markdown report\n    md_report = f\"\"\"# Medical Image Classification Report\n\n## Training Summary\n- **Training Date**: {summary['training_completed']}\n- **Total Epochs**: {summary['final_epoch']}\n- **Best Validation Accuracy**: {summary['best_val_accuracy']:.4f} (Epoch {summary['best_epoch']})\n\n## Final Performance\n- **Training Loss**: {summary['final_train_loss']:.4f}\n- **Validation Loss**: {summary['final_val_loss']:.4f}\n- **Training Accuracy**: {summary['final_train_accuracy']:.4f}\n- **Validation Accuracy**: {summary['final_val_accuracy']:.4f}\n- **Test Set Accuracy**: {summary['test_set_accuracy']:.4f}\n\n## External Validation\n- **External Test Accuracy**: {summary['external_test_accuracy']:.4f}\n\n## Model Files\n- **Model Weights**: `models/{model_name}.pth`\n- **Training Curves**: `figures/training_curves.png`\n- **ROC Curves**: Available in `figures/` directory\n- **Confusion Matrices**: Available in `figures/` directory\n\n---\n*Report generated automatically by the evaluation pipeline*\n\"\"\"\n    \n    md_path = os.path.join(save_dir, 'reports', 'evaluation_report.md')\n    with open(md_path, 'w') as f:\n        f.write(md_report)\n    print(f\"✅ Markdown report saved to: {md_path}\")\n    \n    return summary\n\n# =======================================================\n# 7. CREATE ZIP FILE FOR DOWNLOAD\n# =======================================================\n\ndef create_zip_for_download(base_dir, zip_name=\"medical_image_classification_results\"):\n    \"\"\"\n    Create a zip file of all results for download\n    \"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"CREATING ZIP FILE FOR DOWNLOAD\")\n    print(\"=\"*60)\n    \n    zip_path = f\"/kaggle/working/{zip_name}.zip\"\n    \n    with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zipf:\n        for root, dirs, files in os.walk(base_dir):\n            for file in files:\n                file_path = os.path.join(root, file)\n                arcname = os.path.relpath(file_path, os.path.dirname(base_dir))\n                zipf.write(file_path, arcname)\n    \n    zip_size = os.path.getsize(zip_path) / (1024 * 1024)  # Size in MB\n    print(f\"✅ Results zipped successfully!\")\n    print(f\"✅ Zip file location: {zip_path}\")\n    print(f\"✅ File size: {zip_size:.2f} MB\")\n    print(f\"\\n📥 Download link will appear above in Kaggle output\")\n    \n    return zip_path\n\n# =======================================================\n# 8. MAIN EXECUTION PIPELINE\n# =======================================================\n\ndef run_complete_evaluation_pipeline(model, test_dataloader, ext_test_dataloader, \n                                     class_names, device, results):\n    \"\"\"\n    Run the complete evaluation pipeline and save all results\n    \"\"\"\n    print(\"\\n\" + \"=\"*60)\n    print(\"STARTING COMPLETE EVALUATION PIPELINE\")\n    print(\"=\"*60)\n    print(f\"Device: {device}\")\n    print(f\"Number of classes: {len(class_names)}\")\n    print(f\"Class names: {class_names}\")\n    \n    # 1. Plot and save training curves\n    print(\"\\n📈 Step 1/6: Plotting training curves...\")\n    plot_and_save_curves(results, dirs['figures'])\n    \n    # 2. Evaluate on standard test set\n    print(\"\\n📊 Step 2/6: Evaluating on standard test set...\")\n    test_accuracy, test_report, test_cm = evaluate_and_save_metrics(\n        model, test_dataloader, class_names, device, \n        \"Standard_Test_Set\", dirs['metrics']\n    )\n    \n    # 3. Evaluate on external test set\n    print(\"\\n📊 Step 3/6: Evaluating on external test set...\")\n    ext_test_accuracy, ext_test_report, ext_test_cm = evaluate_and_save_metrics(\n        model, ext_test_dataloader, class_names, device,\n        \"External_Test_Set\", dirs['metrics']\n    )\n    \n    # 4. Plot ROC curves for standard test set\n    print(\"\\n📈 Step 4/6: Generating ROC curves for standard test set...\