].plot(results[\"test_acc\"], label=\"Test Acc\", color='#ff7f0e', linewidth=2)\nif \"ext_test_acc\" in results:\n    axes[1].plot(results[\"ext_test_acc\"], label=\"External Test Acc\", color='#2ca02c', linestyle='--', linewidth=2)\naxes[1].set_title(\"DeiT: Accuracy Curves\", fontweight='bold', pad=10)\naxes[1].set_xlabel(\"Epochs\")\naxes[1].set_ylabel(\"Accuracy\")\naxes[1].grid(True, linestyle='--', alpha=0.5)\naxes[1].legend(frameon=True, facecolor='white', edgecolor='none')\n\nplt.tight_layout()\nplt.savefig(os.path.join(OUTPUT_DIR, \"deit_training_history_curves.png\"), dpi=300, bbox_inches='tight')\nplt.show()\n\n# ---------------------------------------------------------\n# ৭. Confusion Matrix & Classification Report\n# ---------------------------------------------------------\ndef evaluate_and_plot_metrics(model, dataloader, class_names, device, dataset_name=\"Test Set\"):\n    filename_suffix = dataset_name.lower().replace(\" \", \"_\")\n    print(f\"\\n=========================================\")\n    print(f\"Evaluating Metrics on: {dataset_name}\")\n    print(f\"=========================================\\n\")\n    \n    model.eval()\n    y_true, y_pred = [], []\n    with torch.inference_mode():\n        for X, y in dataloader:\n            X = X.to(device)\n            outputs = model(X)\n            predictions = torch.argmax(outputs.logits, dim=1)\n            y_true.extend(y.cpu().numpy())\n            y_pred.extend(predictions.cpu().numpy())\n            \n    # Text Report সেভ করা\n    report_text = classification_report(y_true, y_pred, target_names=class_names)\n    print(\"--- Classification Report ---\")\n    print(report_text)\n    \n    report_path = os.path.join(OUTPUT_DIR, f\"deit_classification_report_{filename_suffix}.txt\")\n    with open(report_path, \"w\") as f:\n        f.write(f\"DeiT Classification Report - {dataset_name}\\n\")\n        f.write(\"=\"*40 + \"\\n\")\n        f.write(report_text)\n    \n    # Heatmap জেনারেট করা\n    cm = confusion_matrix(y_true, y_pred)\n    plt.figure(figsize=(6.5, 5.5))\n    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', \n                xticklabels=class_names, yticklabels=class_names,\n                square=True, cbar=True, linewidths=.5,\n                annot_kws={\"size\": 12, \"weight\": \"bold\"})\n    \n    plt.title(f'DeiT Confusion Matrix: {dataset_name}', fontweight='bold', pad=12)\n    plt.ylabel('True Label', fontweight='bold', labelpad=8)\n    plt.xlabel('Predicted Label', fontweight='bold', labelpad=8)\n    plt.xticks(rotation=45, ha='right')\n    plt.yticks(rotation=0)\n    plt.tight_layout()\n    \n    plt.savefig(os.path.join(OUTPUT_DIR, f\"deit_confusion_matrix_{filename_suffix}.png\"), dpi=300, bbox_inches='tight')\n    plt.show()\n\nevaluate_and_plot_metrics(deit_model, test_dataloader, class_names, Config.DEVICE, dataset_name=\"Standard Test Set\")\nevaluate_and_plot_metrics(deit_model, ext_test_dataloader, class_names, Config.DEVICE, dataset_name=\"External Test Set\")\n\n# ---------------------------------------------------------\n# ৮. Multi-Class ROC Curve\n# ---------------------------------------------------------\ndef plot_multiclass_roc(model, dataloader, class_names, device, dataset_name=\"Test Set\"):\n    filename_suffix = dataset_name.lower().replace(\" \", \"_\")\n    print(f\"\\nGenerating ROC Curve for: {dataset_name}...\")\n    \n    model.eval()\n    y_true, y_probs = [], []\n    \n    with torch.inference_mode():\n        for X, y in dataloader:\n            X = X.to(device)\n            outputs = model(X)\n            probabilities = torch.softmax(outputs.logits, dim=1)\n            y_true.extend(y.cpu().numpy())\n            y_probs.extend(probabilities.cpu().numpy())\n            \n    y_true = np.array(y_true)\n    y_probs = np.array(y_probs)\n    n_classes = len(class_names)\n    y_true_bin = label_binarize(y_true, classes=range(n_classes))\n    \n    plt.figure(figsize=(7.5, 6))\n    colors = ['#1f77b4', '#2c